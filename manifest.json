{
  "manifest_version": 3,
  "name": "Leafy",
  "version": "1.2.0",
  "description": "Automatically logs your learning progress to GitHub contributions",
  "browser_specific_settings": {
    "gecko": {
      "id": "progress-push@your-domain.com",
      "strict_min_version": "112.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.coursera.org/*",
    "https://*.duolingo.com/*",
    "https://api.github.com/*",
    "https://hackerrank.com/*",
    "https://*.hackerrank.com/*",
    "https://codeforces.com/*",
    "https://*.codeforces.com/*",
    "https://*.edx.org/*",
    "https://learning.edx.org/*",
    "https://udemy.com/*",
    "https://*.udemy.com/*",
    "https://youtube.com/*",
    "https://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content/leetcode.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.coursera.org/*"],
      "js": ["content/coursera.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://*.duolingo.com/*"],
      "js": ["content/duolingo.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://hackerrank.com/*", "https://*.hackerrank.com/*"],
      "js": ["content/hackerrank.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://codeforces.com/*", "https://*.codeforces.com/*"],
      "js": ["content/codeforces.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.edx.org/*", "https://learning.edx.org/*"],
      "js": ["content/edx.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://udemy.com/*", "https://*.udemy.com/*"],
      "js": ["content/udemy.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://youtube.com/*", "https://*.youtube.com/*"],
      "js": ["content/youtube.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Leafy",
    "default_icon": "app_icon_v2.png"
  },
  "icons": {
    "16": "app_icon_v2.png",
    "32": "app_icon_v2.png",
    "48": "app_icon_v2.png",
    "128": "app_icon_v2.png"
  }
}
