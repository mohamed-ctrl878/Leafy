{
  "manifest_version": 3,
  "name": "Progress Push",
  "version": "1.0.0",
  "description": "Automatically logs your learning progress to GitHub contributions",
  "browser_specific_settings": {
    "gecko": {
      "id": "progress-push@your-domain.com",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.coursera.org/*",
    "https://*.duolingo.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content/leetcode.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.coursera.org/*"],
      "js": ["content/coursera.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.duolingo.com/*"],
      "js": ["content/duolingo.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Progress Push",
    "default_icon": "app_icon_v2.png"
  },
  "icons": {
    "16": "app_icon_v2.png",
    "32": "app_icon_v2.png",
    "48": "app_icon_v2.png",
    "128": "app_icon_v2.png"
  }
}
